# Mystic Digits — required environment variables.
# Copy this file to .env.local and fill in real values. .env.local is git-ignored.
# In production, set these in the Vercel project's Environment Variables.

# --- Claude (content engine) ---
ANTHROPIC_API_KEY=

# --- Supabase (orders + PDF storage) ---
# Project URL and keys: Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Razorpay (payments) — added in step 4 ---
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# --- Resend (email) — added in step 5 ---
# RESEND_API_KEY=

# --- Delivery cron (Vercel Cron auth) ---
# CRON_SECRET=

# --- Admin panel auth ---
# Fallback login (username "admin") until a real one is set via /admin/settings,
# which then takes over from the admin_credentials DB row.
# ADMIN_PASSWORD=
# Signs the admin session cookie. Falls back to CRON_SECRET if unset (already
# set), so this is optional.
# ADMIN_SESSION_SECRET=

# --- Local PDF rendering (Windows dev) ---
# Path to system Chrome; used by the Puppeteer render scripts locally.
# CHROME_PATH=C:/Program Files/Google/Chrome/Application/chrome.exe
